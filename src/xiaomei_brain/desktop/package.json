{
  "name": "xiaomei-brain-desktop",
  "version": "0.1.0",
  "description": "xiaomei-brain Desktop Client",
  "author": "李白 libai <iamlibai2@gmail.com>",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "dev:renderer": "vite dev",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "runtime:win": "node scripts/build-windows-runtime.mjs",
    "package": "npm run package:win",
    "package:win": "npm run runtime:win && npm run build && electron-builder --win msi",
    "start": "electron ."
  },
  "dependencies": {
    "extract-zip": "^2.0.1",
    "immer": "^11.1.11",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "concurrently": "^9.0.0",
    "electron": "^37.10.3",
    "electron-builder": "^25.0.0",
    "i18next": "^25.7.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-i18next": "^16.3.5",
    "react-markdown": "^9.0.0",
    "react-syntax-highlighter": "^15.6.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
